# Supabase
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxxxx

# Oracle backend (upload, stream, archive)
VITE_BACKEND_URL=https://api.yourdomain.com
VITE_API_URL=https://api.yourdomain.com

# Cloudflare R2 (optional direct upload path)
VITE_R2_ACCOUNT_ID=
VITE_R2_ACCESS_KEY_ID=
VITE_R2_SECRET_ACCESS_KEY=
VITE_R2_BUCKET=cogallery

# App
VITE_APP_URL=http://localhost:5173

# WebRTC TURN (optional — improves P2P behind strict NAT)
VITE_TURN_URL=turn:your-turn-server.com:3478
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Observability (optional)
VITE_SENTRY_DSN=

# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ARCHIVE=true
